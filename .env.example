# AI Configuration (OpenAI-compatible API)
# Default: Ollama local (http://localhost:11434/v1)
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=qwen2.5:7b

# SerpAPI (for Google Patents online search)
# Get your key at https://serpapi.com/
SERPAPI_KEY=your-serpapi-key-here

# For OpenAI:
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-your-key
# AI_MODEL=gpt-4o

# For other compatible APIs (DeepSeek, etc.):
