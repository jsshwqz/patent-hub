# Patent Hub Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# All keys can also be configured in the Settings page (http://localhost:3000/settings)

# ── AI Service (Required for AI features) ─────────────────────────────────
# Supports any OpenAI-compatible API: GLM, DeepSeek, OpenAI, Ollama, etc.
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=your-api-key-here
AI_MODEL=glm-4-flash

# ── Fallback AI Providers (Optional, auto-switch on failure) ──────────────
# Up to 5 fallback providers. Format: FALLBACK_AI_{1-5}_{URL|KEY|MODEL|NAME}
# FALLBACK_AI_1_NAME=OpenRouter
# FALLBACK_AI_1_URL=https://openrouter.ai/api/v1
# FALLBACK_AI_1_KEY=your-openrouter-key
# FALLBACK_AI_1_MODEL=google/gemini-2.0-flash-exp:free

# FALLBACK_AI_2_NAME=Google Gemini
# FALLBACK_AI_2_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# FALLBACK_AI_2_KEY=your-gemini-key
# FALLBACK_AI_2_MODEL=gemini-2.0-flash

# ── SerpAPI (Optional, for online patent search) ─────────────────────────
# Get your key at: https://serpapi.com/
# Without this key, search uses local database only
SERPAPI_KEY=your-serpapi-key-here

# ── Server (Optional) ────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=3000
