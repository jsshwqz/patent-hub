{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Patent Hub",
  "version": "0.3.0",
  "identifier": "com.patenthub.app",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:3000/search"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Patent Hub",
        "width": 1200,
        "height": 800,
        "minWidth": 375,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:3000/search"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:3000; img-src 'self' http://localhost:3000 data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
